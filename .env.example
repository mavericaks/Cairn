# ═══════════════════════════════════════════════════════════════════
# Cairn Environment Variables — .env.example (E1-T10, ADR-007)
# ═══════════════════════════════════════════════════════════════════
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in real values for REQUIRED variables below
#   3. .env is gitignored — never commit real credentials
#
# RULE 14: Every credential, URL, and environment-specific value
# is externalized as an environment variable from the first line
# it is needed. No hardcoded credentials anywhere. Ever.
# ═══════════════════════════════════════════════════════════════════


# ─── REQUIRED ─────────────────────────────────────────────────────
# These must be set in production (Railway dashboard).
# Locally, application.yml has defaults for docker-compose dev setup.
# ──────────────────────────────────────────────────────────────────

# PostgreSQL connection URL (E1-T3)
# Format: jdbc:postgresql://<host>:<port>/<database>
# Railway: auto-populated when you add a PostgreSQL service
# Local default: jdbc:postgresql://localhost:5432/cairn
DB_URL=jdbc:postgresql://localhost:5432/cairn

# PostgreSQL credentials (E1-T3)
# Railway: auto-populated from PostgreSQL service
# Local default: cairn / cairn (matches docker-compose.yml)
DB_USERNAME=cairn
DB_PASSWORD=cairn


# ─── OPTIONAL ─────────────────────────────────────────────────────
# These have sensible defaults. Override only when needed.
# ──────────────────────────────────────────────────────────────────

# HTTP server port
# Railway: auto-set by the platform (do NOT set manually)
# Local default: 8080
# PORT=8080

# Log file directory (E1-T4)
# Where logback-spring.xml writes cairn.log
# Local default: logs (relative to working directory)
# LOG_PATH=logs

# Active Spring profile
# 'prod' activates structured JSON console logging (logback-spring.xml)
# Dockerfile sets this to 'prod' automatically — no need to set in Railway
# Locally, leave unset for human-readable console output
# SPRING_PROFILES_ACTIVE=prod


# ─── FUTURE (Epic 2+) ────────────────────────────────────────────
# Not yet used — documented here for forward reference.
# Uncomment and fill when implementing their respective Epics.
# ──────────────────────────────────────────────────────────────────

# Gemini API key(s) for LLM calls via OpenAI-compatible endpoint (ADR-003)
# Format: comma-separated keys for round-robin rotation
# Example: OPENAI_API_KEY=key1,key2,key3
# OPENAI_API_KEY=your-gemini-api-key-here

# Gemini OpenAI-compatible base URL (ADR-003)
# Default: https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Redis Cloud connection URL for domain context cache (ADR-004)
# Format: redis://<user>:<password>@<host>:<port>
# Railway: auto-populated when you add a Redis service
REDIS_URL=redis://default:password@localhost:6379
